# === Server ===
PORT=3001
CORS_ORIGIN_FRONTEND=http://localhost:5173

# === Better Auth ===
BETTER_AUTH_SECRET=generame-un-secret-de-32-chars-minimo # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001

# === Database ===
DATABASE_URL=postgres://postgres:postgres@localhost:5432/saas_dev

# === OAuth (optional — leave empty to disable) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Assets / Storage ===
ASSET_PROVIDER=local
ASSET_LOCAL_DIR=dev_only/uploads
ASSET_MAX_SIZE_MB=10
# S3-compatible (see packages/docs/storage-s3.md)
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# === Redis ===
REDIS_URL=redis://localhost:6379

# === AI Providers (optional — leave empty to disable the corresponding models) ===
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Email / SMTP ===
# Dev: Mailpit (docker-compose) on port 1025, UI at http://localhost:8025
# Prod: set SMTP_HOST/PORT/USER/PASS to your provider (Resend, Brevo, SES, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SaaS Template <noreply@localhost>
SMTP_SECURE=false