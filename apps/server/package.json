{
  "name": "@saas-template/server",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "jobs:scaffold": "tsx scripts/generate-jobs.ts",
    "dev": "tsx scripts/generate-jobs.ts --watch & tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "make-admin": "tsx scripts/make-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2",
    "@ai-sdk/openai": "^2",
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.3.0",
    "@repo/shared": "workspace:^",
    "ai": "^5",
    "better-auth": "^1.6.0",
    "bullmq": "^5.73.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "resumable-stream": "^2",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}